    "start:scheduler": "node dist/index.js --scheduler",
    "metrics": "tsx ../research/jobs/run-rolling-metrics.ts",
    "weights": "tsx ../research/jobs/run-dynamic-weight.ts",
    "backtest": "tsx ../research/jobs/run-backtest.ts",
    "regime": "tsx ../research/jobs/run-regime.ts",
    "maintenance": "tsx ../research/jobs/run-maintenance.ts"
  },
  "dependencies": {
    "@gr2/shared": "file:../shared",
    "@gr2/token-price-fetcher": "file:../token-price-fetcher",
    "x-scaper": "file:../x-scaper",
    "@gr2/signal-detector": "file:../signal-detector",
    "@gr2/proposal-generator": "file:../layer3",
    "node-cron": "^3.0.3"
  }
}
