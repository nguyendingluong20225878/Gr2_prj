{
  "name": "@gr2/run",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx --env-file=.env src/index.ts --once",
    "dev:scheduler": "tsx --env-file=.env src/index.ts --scheduler",
