{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    /* Override cho Next.js */
    "baseUrl": ".",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    
    /* Plugins */
    "plugins": [
      {
        "name": "next"
      }
    ],
    
    /* Alias riêng cho Web (nếu cần) */
    "paths": {
      "@/*": ["./*"],
      "@gr2/shared": ["../../core/shared/dist/index.js"],
      "@gr2/shared/*": ["../../core/shared/dist/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
