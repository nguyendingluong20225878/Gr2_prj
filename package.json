{
  "name": "gr2_project",
  "version": "1.0.0",
  "description": "GR2 Project - Monorepo for Web3 Signal Detection and Proposal Generation",
  "private": true,
  "packageManager": "npm@10.8.1",
  "workspaces": [
    "apps/*",
    "core/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:phase2": "node scripts/run-concurrent.mjs \"npm run scraper\" \"npm run metrics\" \"npm run weights\" \"npm run signal\"",
    "pipeline": "npm run pipeline:core",
    "pipeline:core": "npm --workspace @gr2/run run dev",
    "pipeline:batch": "npm run pipeline:core",
    "pipeline:scheduler": "npm --workspace @gr2/run run dev:scheduler",
    "build": "turbo run build",
    "scraper": "npm --workspace x-scaper run scraper",
    "news": "npm --workspace @gr2/news-scraper run scraper",
    "metrics": "tsx --env-file=core/research/.env core/research/jobs/run-rolling-metrics.ts",
    "weights": "tsx --env-file=core/research/.env core/research/jobs/run-dynamic-weight.ts",
    "signal": "npm --workspace @gr2/signal-detector run quant",
    "regime": "tsx --env-file=core/research/.env core/research/jobs/run-regime.ts",
    "maintenance": "tsx --env-file=core/research/.env core/research/jobs/run-maintenance.ts",
    "backtest": "tsx --env-file=core/research/.env core/research/jobs/run-backtest.ts",
    "quant": "node scripts/run-concurrent.mjs \"npm run backtest\" \"npm run weights\"",
    "start": "npm --workspace @gr2/run run start",
    "demo:backfill-prices": "npm --workspace @gr2/token-price-fetcher run backfill:demo",
    "prices:backfill:1d": "npm --workspace @gr2/token-price-fetcher run backfill:history:1d",
    "backtest:outcome": "tsx --env-file=core/research/.env core/research/backtest/run-backtest.ts --horizon-hours=24 --delay-ms=0 --batch-delay-ms=0",
    "demo:backtest": "npm run backtest:outcome",
    "demo:prepare-data": "npm run demo:backfill-prices && npm run backtest:outcome",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/mongoose": "^5.11.96",
    "@types/node": "^24.10.1",
    "@types/selenium-webdriver": "^4.35.4",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@types/node": "^20.11.0",
    "fast-xml-parser": "^5.7.2",
    "mongoose": "^9.0.0",
    "selenium-webdriver": "^4.38.0",
    "turbo": "^1.12.0",
    "typescript": "^5.3.3"
  }
}
